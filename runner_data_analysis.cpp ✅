#include <iostream>
#include <fstream>
#include <string>
#include <iomanip>

using namespace std;

void getData(ifstream& inf, string n[], double runData[][8], int count);
void calculateAverage(double runData[][8], int count);
void print(string n[], double runData[][8], int count);

int main()
{
    // Create arrays
    string names[5];
    double runnerData[5][8];

    // Open file
    ifstream inputfile("ch8_Ex12Data.txt");

    if (inputfile)
    {
        getData(inputfile, names, runnerData, 5);
    }
    else
    {
        cout << "Error reading input file" << endl;
        return 0;
    }

    inputfile.close();

    calculateAverage(runnerData, 5);
    print(names, runnerData, 5);

    return 0;
}

// Input the data from the file
void getData(ifstream& inf, string n[], double runData[][8], int count)
{
    for (int i = 0; i < count; i++)
    {
        inf >> n[i];
        for (int j = 0; j < 7; j++)
        {
            inf >> runData[i][j];
        }
    }
}

// Calculate the runners weekly average
void calculateAverage(double runData[][8], int count)
{
    double totalRan;

    for (int i = 0; i < count; i++)
    {
        totalRan = 0;
        double average;

        for (int j = 0; j < 7; j++)
        {
            totalRan += runData[i][j];
        }

        average = totalRan / 7;
        runData[i][7] = average; // store average in last column
    }
}

// Output the data in table format
void print(string n[], double runData[][8], int count)
{
    // Header row
    cout << "Name ";
    for (int i = 0; i < 7; i++)
    {
        cout << "Day " << (i + 1) << " ";
    }
    cout << "Average" << endl;

    // Data rows
    for (int i = 0; i < count; i++)
    {
        cout << fixed << showpoint << setprecision(2);
        cout << n[i] << " ";

        for (int j = 0; j < 7; j++)
        {
            cout << runData[i][j] << " ";
        }

        cout << runData[i][7];
        cout << endl;
    }
}
